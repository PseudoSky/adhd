# agent-mcp environment — copy to `.env` (repo root) or `~/.adhd/.env`, then fill secrets.
#
# The server loads, in order (most-specific wins): <cwd>/.env → <cwd>/.adhd/.env → ~/.adhd/.env.
# `nx serve agent-mcp` runs from the repo root, so a repo-root `.env` is picked up
# automatically; machine-wide secrets are best kept in `~/.adhd/.env`.
#
# Non-secret config below is set to sensible defaults for the chat-gateway dev stack.
# All vars use the ADHD_AGENT_ prefix; only ADHD_AGENT_-prefixed names may be referenced
# from agent provider configs (extend with ADHD_AGENT_ENV_ALLOWLIST).

# ── Provider credentials (SECRET — fill these; never commit a real .env) ─────
# Anthropic API key OR OAuth bearer token (from `claude setup-token`)
# ADHD_AGENT_ANTHROPIC_SECRET=sk-ant-...
# DeepSeek API key
# ADHD_AGENT_DEEPSEEK_SECRET=sk-...
# OpenAI / OpenAI-compatible API key
# ADHD_AGENT_OPENAI_SECRET=sk-...
# ADHD_AGENT_OPENAI_BASE_URL=http://localhost:1234/v1

# ── Database (defaulted) ─────────────────────────────────────────────────────
# Dev DB used by the chat-gateway stack (holds your gateway test agents).
# Production default (when unset) is ~/.adhd/agent-mcp/agents.db.
ADHD_AGENT_DATABASE_PATH=data/agent-mcp/agents-dev.db

# ── SSE / chat-gateway (defaulted) ───────────────────────────────────────────
ADHD_AGENT_SSE_PORT=3010
# 0.0.0.0 so chat UIs / Docker containers can reach the gateway.
# SECURITY: this binds all interfaces — set 127.0.0.1 to restrict to localhost.
ADHD_AGENT_SSE_HOST=0.0.0.0
# ADHD_AGENT_SSE_BASE_URL=http://localhost:3010

# ── Logging (defaulted) ──────────────────────────────────────────────────────
ADHD_AGENT_LOG_LEVEL=info

# ── Orchestration limits (code defaults shown; uncomment to override) ────────
# ADHD_AGENT_MAX_DEPTH=5
# ADHD_AGENT_MAX_TOOL_LOOPS=50
# ADHD_AGENT_CONTEXT_LIMIT=0
# ADHD_AGENT_DEFAULT_MAX_TOKENS=8192
# ADHD_AGENT_QUEUE_CONCURRENCY=5
# ADHD_AGENT_ALLOWED_AGENTS=

# ── Security / plugins (code defaults shown; uncomment to override) ──────────
# ADHD_AGENT_ENV_ALLOWLIST=
# ADHD_AGENT_CONFIG=
# ADHD_AGENT_PLUGINS=
