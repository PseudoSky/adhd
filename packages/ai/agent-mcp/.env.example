# agent-mcp environment variables
#
# Copy the relevant lines to ~/.adhd/.env (recommended — loaded automatically
# at startup from all three locations: ~/.adhd/.env, <cwd>/.adhd/.env, <cwd>/.env).
#
# All variables use the ADHD_AGENT_ prefix. Secrets must start with
# ADHD_AGENT_ (or be listed in ADHD_AGENT_ENV_ALLOWLIST) to be accessible
# from agent provider configs.
#
# ── Provider credentials ────────────────────────────────────────────────────

# OpenAI / OpenAI-compatible API key
# (not required for local LM Studio / Ollama — localhost has no credential check)
# ADHD_AGENT_OPENAI_SECRET=sk-...

# Override the OpenAI base URL to point at a local or custom server
# ADHD_AGENT_OPENAI_BASE_URL=http://localhost:1234/v1

# Anthropic API key or OAuth bearer token (from `claude setup-token`)
# ADHD_AGENT_ANTHROPIC_SECRET=sk-ant-...

# DeepSeek API key
# ADHD_AGENT_DEEPSEEK_SECRET=sk-...

# ── Database ─────────────────────────────────────────────────────────────────

# Absolute path to the SQLite database (created automatically if absent).
# Default: ~/.adhd/agent-mcp/agents.db
# ADHD_AGENT_DATABASE_PATH=/Users/you/.adhd/agent-mcp/agents.db

# ── Orchestration limits ─────────────────────────────────────────────────────

# Maximum recursion depth (agent → sub-agent nesting). Default: 5
# ADHD_AGENT_MAX_DEPTH=5

# Maximum tool calls per task. Default: 50
# ADHD_AGENT_MAX_TOOL_LOOPS=50

# Estimated token limit for the message window passed to each provider call.
# 0 = disabled. When > 0, set ~10% below the model's actual context window.
# ADHD_AGENT_CONTEXT_LIMIT=0

# Default max_tokens for Anthropic providers that don't set maxTokens. Default: 8192
# ADHD_AGENT_DEFAULT_MAX_TOKENS=8192

# Comma-separated server-wide agent allowlist (overridden per-agent by permissions.allowedAgents)
# ADHD_AGENT_ALLOWED_AGENTS=

# ── Queue ────────────────────────────────────────────────────────────────────

# Max concurrent background tasks. Default: 5
# ADHD_AGENT_QUEUE_CONCURRENCY=5

# ── Logging ──────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal | silent. Default: info
# ADHD_AGENT_LOG_LEVEL=info

# ── SSE streaming ────────────────────────────────────────────────────────────

# Port the SSE server listens on. Default: 3001
# ADHD_AGENT_SSE_PORT=3001

# Host the SSE server binds to. Default: 127.0.0.1
# ADHD_AGENT_SSE_HOST=127.0.0.1

# Public base URL for stream_url links. Default: http://localhost:{SSE_PORT}
# ADHD_AGENT_SSE_BASE_URL=http://localhost:3001

# ── Security ─────────────────────────────────────────────────────────────────

# Comma-separated env-var names agents may reference that don't start with ADHD_AGENT_.
# ADHD_AGENT_ENV_ALLOWLIST=

# ── Plugins ──────────────────────────────────────────────────────────────────

# Absolute path to the agent-mcp plugin config YAML
# ADHD_AGENT_CONFIG=

# Comma-separated absolute paths to plugin entry files
# ADHD_AGENT_PLUGINS=
