# =========================
# TRANSPORT
# =========================

# Transport mode: stdio | http | sse
TRANSPORT=stdio

# Port to listen on (http/sse mode only)
PORT=3000


# =========================
# DATABASE
# =========================

DATABASE_PATH=./data/agents.db


# =========================
# POLICY
# =========================

# Maximum recursion depth for agent delegation (default: 5)
MAX_DEPTH=5

# Maximum tool call iterations per task (default: 10)
MAX_TOOL_LOOPS=10

# Comma-separated list of allowed agent names at the server level.
# Leave empty to allow any agent to be called (unrestricted).
ALLOWED_AGENTS=


# =========================
# QUEUE
# =========================

# Maximum concurrent background tasks (default: 5)
QUEUE_CONCURRENCY=5


# =========================
# LOGGING
# =========================

LOG_LEVEL=info


# =========================
# PROVIDERS
# =========================

ANTHROPIC_API_KEY=

OPENAI_API_KEY=

# LM Studio local server base URL
LMSTUDIO_BASE_URL=http://localhost:1234/v1
