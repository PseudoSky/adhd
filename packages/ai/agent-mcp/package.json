{
  "name": "@adhd/agent-mcp",
  "version": "0.0.1",
  "description": "Stateful MCP-native agent runtime with provider abstraction and recursive delegation",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/packages/ai/agent-mcp/index.d.ts",
      "default": "./dist/packages/ai/agent-mcp/index.js"
    }
  },
  "scripts": {
    "build": "nx build agent-mcp",
    "dev": "nx build agent-mcp --watch",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.96.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.10.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "openai": "6.37.0",
    "p-queue": "9.2.0",
    "p-retry": "^4.6.2",
    "pino": "10.3.1",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^1.0.4",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "13.1.3",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vite": "~5.0.13",
    "vite-plugin-dts": "~3.8.3",
    "vitest": "^1.6.0"
  }
}
