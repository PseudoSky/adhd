# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.

# ── agent-mcp provider secrets ──────────────────────────────────────────────
# Real key/token values (the gateway resolves the agents' env-pointer names to these).
ADHD_AGENT_ANTHROPIC_SECRET=sk-ant-...
ADHD_AGENT_DEEPSEEK_SECRET=sk-...
# ADHD_AGENT_OPENAI_SECRET=sk-...

# ── LibreChat required secrets ──────────────────────────────────────────────
# Generate fresh values (do NOT reuse these placeholders):
#   CREDS_KEY:        openssl rand -hex 32     (64 hex chars)
#   CREDS_IV:         openssl rand -hex 16     (32 hex chars)
#   JWT_SECRET:       openssl rand -hex 32
#   JWT_REFRESH_SECRET: openssl rand -hex 32
#   MEILI_MASTER_KEY: openssl rand -hex 16
CREDS_KEY=REPLACE_64_HEX
CREDS_IV=REPLACE_32_HEX
JWT_SECRET=REPLACE_RANDOM
JWT_REFRESH_SECRET=REPLACE_RANDOM
MEILI_MASTER_KEY=REPLACE_RANDOM
ALLOW_REGISTRATION=true
