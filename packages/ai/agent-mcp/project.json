{
  "name": "agent-mcp",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ai/agent-mcp/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": ["layer:ai", "platform:node"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/ai/agent-mcp",
        "main": "packages/ai/agent-mcp/src/index.ts",
        "tsConfig": "packages/ai/agent-mcp/tsconfig.lib.json",
        "clean": true,
        "assets": [
          {
            "input": "packages/ai/agent-mcp",
            "glob": "drizzle/**/*",
            "output": "."
          }
        ]
      }
    },

    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/packages/ai/agent-mcp/src/index.js",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build"],
      "metadata": {
        "description": "Build + run the agent-mcp server, including the OpenAI-compatible chat gateway on the SSE host/port. Config (incl. ADHD_AGENT_* defaults) is loaded from .env / ~/.adhd/.env — see packages/ai/agent-mcp/.env.example. Run: `npx nx serve agent-mcp`."
      }
    },

    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx build agent-mcp --watch"
      }
    },

    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/ai/agent-mcp/tsconfig.json --noEmit"
      }
    },

    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist/packages/ai/agent-mcp"
      }
    },
    "nx-release-publish": {
      "dependsOn": ["build", "test"],
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },

    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/packages/ai/agent-mcp"],
      "options": {
        "configFile": "packages/ai/agent-mcp/vite.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
