{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/packages/ai/agent-registry",
    "rootDir": "./src",
    "baseUrl": "../../..",
    "ignoreDeprecations": "6.0",

    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022"],

    "moduleResolution": "Bundler",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"],

    "noEmit": false
  },
  "files": [],
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
