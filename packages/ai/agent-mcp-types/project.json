{
  "name": "agent-mcp-types",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ai/agent-mcp-types/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": ["layer:mcp", "platform:shared"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/ai/agent-mcp-types",
        "main": "packages/ai/agent-mcp-types/src/index.ts",
        "tsConfig": "packages/ai/agent-mcp-types/tsconfig.lib.json",
        "assets": ["packages/ai/agent-mcp-types/*.md"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
