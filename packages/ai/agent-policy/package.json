{
  "name": "@adhd/agent-policy",
  "version": "0.0.1",
  "description": "Policy engine for @adhd/agent-mcp — permission, safety, audit, rate, scope, compliance, and quality policies with SQLite/Drizzle persistence",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "drizzle"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "build": "nx build agent-policy",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@adhd/agent-mcp-types": "*",
    "better-sqlite3": "12.10.0",
    "drizzle-orm": "0.45.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^1.0.4",
    "drizzle-kit": "^0.31.10",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vite": "~5.0.13",
    "vite-plugin-dts": "~3.8.3",
    "vitest": "^1.6.0"
  }
}
