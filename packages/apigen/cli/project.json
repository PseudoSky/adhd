{
  "name": "apigen-cli",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/apigen/cli/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": [
    "layer:entrypoints",
    "platform:node"
  ],
  "targets": {
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{workspaceRoot}/coverage/packages/apigen/cli"
      ],
      "options": {
        "configFile": "packages/apigen/cli/vite.config.ts"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/apigen/cli",
        "main": "packages/apigen/cli/src/index.ts",
        "tsConfig": "packages/apigen/cli/tsconfig.lib.json",
        "assets": [
          "packages/apigen/cli/*.md"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      },
      "dependsOn": [
        "build",
        "test"
      ]
    }
  }
}
