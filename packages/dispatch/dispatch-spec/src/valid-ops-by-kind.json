{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adhd.dev/schemas/valid-ops-by-kind.json",
  "title": "Valid Shape Ops by Kind",
  "description": "Mapping from shape.kind to allowed ShapeOpType values. Any consumer (TypeScript validator, Python MCP server, Go AST transformer) can read this file to determine which ops are valid for a given kind without importing TypeScript code.",
  "mapping": {
    "function": [
      "add-param",
      "remove-param",
      "rename-param",
      "retype-param",
      "change-param-optional",
      "reorder-params",
      "change-return"
    ],
    "interface": [
      "add-field",
      "remove-field",
      "rename-field",
      "retype-field",
      "change-field-optional",
      "add-generic",
      "remove-generic",
      "constrain-generic",
      "add-extends",
      "remove-extends"
    ],
    "type": ["add-field", "remove-field", "retype-field"],
    "class": [
      "add-field",
      "remove-field",
      "rename-field",
      "retype-field",
      "change-field-optional",
      "add-param",
      "add-generic",
      "remove-generic",
      "constrain-generic",
      "add-extends",
      "remove-extends"
    ],
    "enum": ["add-field", "remove-field", "rename-field"],
    "const": ["add-var", "remove-var", "rename-var", "change-default"],
    "config": [
      "set-key",
      "remove-key",
      "rename-key",
      "add-entry",
      "remove-entry",
      "update-entry",
      "bump-version",
      "update-checksum"
    ],
    "env": ["set-key", "remove-key", "rename-key"],
    "schema": [
      "add-table",
      "remove-table",
      "add-column",
      "remove-column",
      "rename-column",
      "retype-column",
      "change-nullable",
      "add-index",
      "remove-index"
    ],
    "manifest": ["add-entry", "remove-entry", "bump-version"],
    "doc": [
      "add-section",
      "remove-section",
      "rename-section",
      "update-section"
    ],
    "structured-output": [],
    "script": [
      "add-param",
      "remove-param",
      "rename-param",
      "retype-param",
      "change-param-optional",
      "reorder-params",
      "change-return",
      "add-field",
      "remove-field",
      "rename-field",
      "retype-field",
      "change-field-optional",
      "add-generic",
      "remove-generic",
      "constrain-generic",
      "add-extends",
      "remove-extends",
      "set-key",
      "remove-key",
      "rename-key",
      "add-array-item",
      "remove-array-item",
      "add-var",
      "remove-var",
      "rename-var",
      "change-default",
      "add-section",
      "remove-section",
      "rename-section",
      "update-section",
      "add-table",
      "remove-table",
      "add-column",
      "remove-column",
      "rename-column",
      "retype-column",
      "change-nullable",
      "add-index",
      "remove-index",
      "add-entry",
      "remove-entry",
      "update-entry",
      "bump-version",
      "update-checksum",
      "add-export"
    ]
  }
}
