{
  "name": "dispatch-spec",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dispatch/dispatch-spec/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag"
      }
    }
  },
  "tags": ["layer:shared", "platform:shared"],
  "targets": {
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/packages/dispatch/dispatch-spec"],
      "options": {
        "configFile": "packages/dispatch/dispatch-spec/vite.config.ts"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/dispatch/dispatch-spec",
        "main": "packages/dispatch/dispatch-spec/src/index.ts",
        "tsConfig": "packages/dispatch/dispatch-spec/tsconfig.lib.json",
        "assets": [
          "packages/dispatch/dispatch-spec/*.md",
          {
            "input": "packages/dispatch/dispatch-spec/src",
            "glob": "*.json",
            "output": "/"
          }
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      },
      "dependsOn": ["build", "test"]
    }
  }
}
