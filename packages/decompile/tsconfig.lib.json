{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "esModuleInterop": false,
    "target": "es2020",
    "moduleResolution": "node",
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "types": ["node"]
  },
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": ["src/**/*.ts","bin/*.ts"]
}
