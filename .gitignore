dist
tmp
/out-tsc
.yarn
# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# Python compiled artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime / ephemeral test artifacts — NEVER tracked, always regenerable.
# Canonical ephemeral-artifacts root is tmp/ (already ignored above): all
# generated output, scratch DBs, and test fixtures write under tmp/<package>/
# and are removable with `nx reset` / a `clean` target. Stray runtime stores
# (SQLite DBs, the repo-root data/ that agent-mcp's ./data default creates,
# scratch MCP servers) are caught here so they can never clutter a commit.
/data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
calc-server.*

.nx/cache
.nx/workspace-data

# Claude Code local state + git worktrees. The worktrees under
# .claude/worktrees/ are full repo copies; if nx scans them it sees every
# project name twice and fails the project graph with
# ProjectsWithConflictingNamesError. Keep this ignored (also prevents
# `git add -A` from sweeping local job/worktree state into commits).
.claude/

# agent-mcp secret store — ADHD_AGENT_* secrets live in ~/.adhd/.env (outside
# the repo) but a project-local .adhd/.env is also supported for convenience.
# Never track it.
.adhd/

# Local env files — may hold secrets; never commit. `.env.example` templates ARE tracked.
.env
.env.local
.env.*.local

# Next.js
.next
out


storybook-static

# agent-mcp live-dag test fixture log (redirected to tmp via CALC_LOG; this is a safety net)
packages/ai/agent-mcp/src/__tests__/integration/fixtures/calc-server.log
