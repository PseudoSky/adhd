{
  "compileOnSave": false,
  "ts-node": {
    "esm": true,
    "compilerOptions": {
      "module": "CommonJS",
      "paths": {
        "@adhd/data": ["./packages/data/src/index.ts"],
        "@adhd/query": ["./packages/query/src/index.ts"],
        "@adhd/react-hooks": ["./packages/react-hooks/src/index.ts"],
        "@adhd/transform": ["./packages/transform/src/index.ts"]
      }
    }
  },
  "compilerOptions": {
    "rootDir": "./",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noImplicitThis": false,
    "importHelpers": true,
    "target": "es2018",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@adhd/agent-mcp": ["./packages/ai/agent-mcp/src/index.ts"],
      "@adhd/agent-mcp-budget": ["./packages/ai/agent-mcp-budget/src/index.ts"],
      "@adhd/agent-mcp-types": ["./packages/ai/agent-mcp-types/src/index.ts"],
      "@adhd/apigen-cli": ["./packages/apigen/cli/src/index.ts"],
      "@adhd/apigen-core": ["./packages/apigen/core/src/index.ts"],
      "@adhd/apigen-nx": ["./packages/apigen/nx/src/index.ts"],
      "@adhd/apigen-plugin-api-express": [
        "./packages/apigen/plugins/api-express/src/index.ts"
      ],
      "@adhd/apigen-plugin-api-fastify": [
        "./packages/apigen/plugins/api-fastify/src/index.ts"
      ],
      "@adhd/apigen-plugin-cli-output": ["./packages/apigen/plugins/cli/src/index.ts"],
      "@adhd/apigen-plugin-jsonschema": [
        "./packages/apigen/plugins/jsonschema/src/index.ts"
      ],
      "@adhd/apigen-plugin-mcp": ["./packages/apigen/plugins/mcp/src/index.ts"],
      "@adhd/apigen-runtime": ["./packages/apigen/runtime/src/index.ts"],
      "@adhd/data": ["./packages/data/src/index.ts"],
      "@adhd/decompile": ["./packages/decompile/src/index.ts"],
      "@adhd/query": ["./packages/query/src/index.ts"],
      "@adhd/react-hooks": ["./packages/react-hooks/src/index.ts"],
      "@adhd/storybook": ["./packages/storybook/src/index.ts"],
      "@adhd/transform": ["./packages/transform/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
