{
  "mcpServers": {
    "agent-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["dist/packages/ai/agent-mcp/src/index.js"],
      "env": {
        "ADHD_AGENT_DATABASE_PATH": "data/agent-mcp/agents-dev.db"
      }
    },
    "agent-mcp-published": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@adhd/agent-mcp@latest"],
      "env": {
        "ADHD_AGENT_DATABASE_PATH": "data/agent-mcp/agents-published.db"
      }
    }
  }
}
